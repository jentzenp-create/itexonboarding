# ============================================================
# ITEX Onboarding Flow — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenRouter (AI ad generation + voice agent) ───────────────
OPENROUTER_API_sk-or-v1-abeb52ec5024594d5283f57123272d01d83bd86c1de91d3a0d21df808774a43f
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ── Resend (transactional email) ──────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=ITEX Onboarding <onboarding@yourdomain.com>
TRADE_DIRECTOR_EMAIL=director@yourdomain.com

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Jotform (pre-qualification form embed) ────────────────────
NEXT_PUBLIC_JOTFORM_URL=https://form.jotform.com/your-form-id

# ── Admin Panel ───────────────────────────────────────────────
ADMIN_PASSWORD=your-secure-admin-password

# ── Cron Security ─────────────────────────────────────────────
# Used to authenticate Vercel cron job calls
CRON_SECRET=your-random-cron-secret
